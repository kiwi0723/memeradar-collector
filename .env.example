# MemeRadar Collector — Environment Variables
# Copy to .env and fill in your values

# Telegram push target (for ★★★ signals)
TG_PUSH_TOKEN=your_bot_token_here
TG_PUSH_CHAT=your_chat_id_here

# Hermes API endpoint (default: localhost)
HERMES_API=http://127.0.0.1:8642/v1/chat/completions

# Collector config
MAX_BUFFER_PER_TOKEN=50
